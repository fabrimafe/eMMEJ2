df.loc[:, 'accession_context'] = df.loc[:, 'accession_context'].str.upper()

"""
Calculating liklyhood and p-value of finding a motif in a
specific distance from the 1st motif.
"""
df['del_mmej_lk'] = np.nan
df['SD_snap_back_lk_bc'] = np.nan
df['SD_loop_out_lk_bc'] = np.nan
df['del_mmej_p_val'] = np.nan
df['SD_snap_back_p_val'] = np.nan
df['snap_freq_motif_eq'] = np.nan
df['SD_loop_out_p_val'] = np.nan
df['loop_freq_motif_eq'] = np.nan
df['del_mmej_geom'] = np.nan
df['del_mmej_lk_MH2'] = np.nan
df['del_mmej_p_val_MH2'] = np.nan
df['del_mmej_freq_motif_eq'] = np.nan
df['del_mmej_freq_motif_eq_MH2'] = np.nan
df['pChance_MMEJ'] = np.nan
df['pChance_MMEJ_MH2'] = np.nan
df['pChance_snap'] = np.nan
df['pChance_loop'] = np.nan

"""
for insertions: the motif is the repeat ('tamplate_switch_repeat')
for  mmej snap back: the motif is the repeat ('S_tamplate_switch_repeat')
for deletions: the motif is the 'mmej_cand'
for all indels the last nucleotide is the one that comes right before the DSB on the reference seq
"""
df.loc[(df['del_mmej'] == True), 'del_motif_d'] = df.loc[(df['del_mmej'] == True), 'indel_len'] - df.loc[(df['del_mmej'] == True), 'del_mmej_cand_len']
# creating a df with only deletions
df_with2K_del_mmej = df.loc[((df['del_mmej'] == True) & 
           (df['indel_type'] == 'DEL')), :].copy()

if probabilitytype=="geometric":
    print("start geometric model calculations for deletions")
    df_with2K_del_mmej['max_length_MH']=df_with2K_del_mmej.apply(lambda row : find_longest_MH(refFA,row['CHR'],row['POS'], row['ancestral_indel']), axis = 1) #useless step
    df_with2K_del_mmej['del_mmej_lk']=df_with2K_del_mmej.apply(lambda row : MH2prob_delNHEJ(refFA,row['CHR'],row['POS'], row['ancestral_indel'], row['max_length_MH']), axis = 1)
    # df_with2K_del_mmej['del_mmej_lk']=df_with2K_del_mmej.apply(lambda row : MH2prob_delNHEJ(refFA,row['CHR'],row['POS'], row['ancestral_indel'], row['del_motif_d']), axis = 1)
    df_with2K_del_mmej['del_mmej_p_val']=df_with2K_del_mmej.apply(lambda row : row['del_mmej_lk'], axis = 1)
    MM_del_df = df_with2K_del_mmej
    print("end calculations")

if probabilitytype=="markov":
    print("start markov model calculations for deletions")
    MM_del_df = df_with2K_del_mmej.apply(
        lambda x: main_markovian_process(
            sequance = x[f"ref_context_seq_{args['windowsize']}bp"] , 
                                 motif = x['del_mmej_cand'],
                                motifs_d = int(x['del_motif_d']),
                    memory_dimer = x['del_last_dimer'],
                    early_stop=1), axis = 1,result_type='expand')
    MM_del_df.rename(columns={0: 'del_mmej_lk', # 'del_mmej_prob', 1:
                1:'del_mmej_p_val',2:'pChance_MMEJ',
                3:'del_mmej_freq_motif_eq'}, inplace=True)
    print("end calculations")

df.loc[ df_with2K_del_mmej.index, 
    ['del_mmej_lk', 'del_mmej_p_val', 'pChance_MMEJ', 'del_mmej_freq_motif_eq']] = MM_del_df.loc[:, 
                    ['del_mmej_lk', 'del_mmej_p_val', 'pChance_MMEJ', 'del_mmej_freq_motif_eq']]  
df.loc[:,'del_mmej_motif_count'] = np.nan
df.loc[df_with2K_del_mmej.index,'del_mmej_motif_count'] = df.loc[df_with2K_del_mmej.index,: ].apply(lambda x: 
    len([m.start() for m in re.finditer(x['del_mmej_cand'], x[f"ref_context_seq_{args['windowsize']}bp"], overlapped=True)]), axis = 1)

# Calculating probs as if MH length = 2 for all deletions
if probabilitytype=="markov":
    df_with2K_del_mmej_mh2 = df_with2K_del_mmej.loc[
        ((df_with2K_del_mmej['indel_len'] >= 2) & 
        (df_with2K_del_mmej['indel_type'] == 'DEL')), :]
    # taking the
    MM_del_df = df_with2K_del_mmej_mh2.apply(
        lambda x: main_markovian_process(
            sequance = x[f"ref_context_seq_{args['windowsize']}bp"] , 
                                motif = x['del_last_dimer'], # using the last dimer as the MH motif is same as taking the shortese MH of length 2
                                motifs_d = int(x['indel_len'] - 2), # this is since the motif here is always of length 2
                    memory_dimer = x['del_last_dimer'],
                    early_stop=1), axis = 1,result_type='expand')
    MM_del_df.rename(columns={0: 'del_mmej_lk_MH2', 
                1:'del_mmej_p_val_MH2',2:'pChance_MMEJ_MH2', 
                3:'del_mmej_freq_motif_eq_MH2'}, inplace=True)
    print("end calculations")

df.loc[ df_with2K_del_mmej_mh2.index, 
    ['del_mmej_lk_MH2', 'del_mmej_p_val_MH2', 
    'pChance_MMEJ_MH2','del_mmej_freq_motif_eq_MH2']] = MM_del_df.loc[:, 
                    ['del_mmej_lk_MH2', 'del_mmej_p_val_MH2', 
                    'pChance_MMEJ_MH2','del_mmej_freq_motif_eq_MH2']]

logging.debug('DEL mmej Markov ends')

logging.debug('Snap back mmej Markov starts')
# creating a df with only mmej snap back
df_with2K_mmej_snap_back = df.loc[(df['SD_snap_back'] == True), :].copy()
MM_snap_df = df_with2K_mmej_snap_back.apply(
    lambda x: main_markovian_process(
                sequance = x[f"ref_context_seq_{args['windowsize']}bp"] , 
                                 motif = x['snap_repeat_pat'],
                                motifs_d = int(x['snap_dist_between_reps']),
                    memory_dimer = x['snap_last_dimer'],
                    early_stop=1), axis = 1 ,result_type='expand')
MM_snap_df.rename(columns={0: 'SD_snap_back_lk_bc', 
                1:'SD_snap_back_p_val', 2:'pChance_snap',3:'snap_freq_motif_eq'}, inplace=True) 
df.loc[ MM_snap_df.index,
    ['SD_snap_back_lk_bc','SD_snap_back_p_val', 
    'pChance_snap', 'snap_freq_motif_eq']] = MM_snap_df.loc[ 
                            :, ['SD_snap_back_lk_bc','SD_snap_back_p_val', 
                            'pChance_snap', 'snap_freq_motif_eq']] 

df.loc[:,'snap_back_motif_count'] = np.nan
df.loc[MM_snap_df.index,'snap_back_motif_count'] = df.loc[MM_snap_df.index,: ].apply(lambda x: 
    len([m.start() for m in re.finditer(x['snap_repeat_pat'], x[f"ref_context_seq_{args['windowsize']}bp"], overlapped=True)]), axis = 1)
logging.debug('Snap back mmej Markov ends')

logging.debug('Loop out mmej Markov starts')
# creating a df with only mmej Loop out
df_with2K_mmej_loop_out = df[df['SD_loop_out'] == True].copy()
MM_loop_df = df_with2K_mmej_loop_out.apply(
    lambda x: main_markovian_process(sequance = x[f"ref_context_seq_{args['windowsize']}bp"] , 
                                 motif = x['loop_repeat_pat'],
                                motifs_d = int(x['loop_dist_between_reps']),
                    memory_dimer = x['loop_last_dimer'],
                    early_stop=1), axis = 1 ,result_type='expand')

MM_loop_df.rename(columns={0: 'SD_loop_out_lk_bc', 
                1:'SD_loop_out_p_val',2: 'pChance_loop', 3:'loop_freq_motif_eq'}, inplace=True) 
df.loc[ MM_loop_df.index,
    ['SD_loop_out_lk_bc', 'SD_loop_out_p_val',
    'pChance_loop','loop_freq_motif_eq']] = MM_loop_df.loc[:, 
                            [ 'SD_loop_out_lk_bc', 'SD_loop_out_p_val',
                            'pChance_loop', 'loop_freq_motif_eq']] 

df.loc[:,'loop_out_motif_count'] = np.nan
df.loc[MM_loop_df.index,'loop_out_motif_count'] = df.loc[MM_loop_df.index,: ].apply(lambda x: 
    len([m.start() for m in re.finditer(x['loop_repeat_pat'], x[f"ref_context_seq_{args['windowsize']}bp"], overlapped=True)]), axis = 1)

logging.debug('Loop out mmej Markov ends')
# If no pattern found, the likelihood of finding a motif by chance
# is == 1.
df.loc[((df['indel_type'] == 'INS') &
    (df['SD_snap_back_lk_bc'].isna())), 'SD_snap_back_lk_bc'] = 1
df.loc[((df['indel_type'] == 'INS') & 
    (df['SD_loop_out_lk_bc'].isna())), 'SD_loop_out_lk_bc'] = 1

# L(unclassified insertions) = L(Snap back by chance) * L(Loop out by chance)
df['unclassified_ins_lk'] = df['SD_snap_back_lk_bc'] * df['SD_loop_out_lk_bc']
# L(SDMMEJ) = 1 - L(unclassified insertions)
df['SDMMEJ_lk'] = 1 - df['unclassified_ins_lk']

# L(Snap back) = (1-L(Snap back by chance)/(2-L(Snap back by chance) - L(Loop out by chance))) * L(SDMMEJ)
df.loc[df['SD_snap_back'], 'SD_snap_back_lk'] = df.loc[
    df['SD_snap_back'], :].apply(lambda row:
    ((1-row['SD_snap_back_lk_bc']+(0.5*10**(-10)))/
        (2-row['SD_snap_back_lk_bc']-row['SD_loop_out_lk_bc'])*row['SDMMEJ_lk']+(1*10**(-10))), axis=1)

# L(Loop out) = (1-L(Loop out by chance)/(2-L(Snap back by chance) - L(Loop out by chance))) * L(SDMMEJ)
df.loc[df['SD_loop_out'], 'SD_loop_out_lk'] = df.loc[
    df['SD_loop_out'], :].apply(lambda row:
    ((1-row['SD_loop_out_lk_bc']+(0.5*10**(-10)))/
        (2-row['SD_snap_back_lk_bc']-row['SD_loop_out_lk_bc'])*row['SDMMEJ_lk']+(1*10**(-10))), axis=1)

df['SD_loop_out_lk'].fillna(value=0, inplace=True)
df['SD_snap_back_lk'].fillna(value=0, inplace=True)
df['SDMMEJ_lk'].fillna(value=0, inplace=True)

# If no pattern found, the likelihood of finding a motif
# NOT by chance is == 0.
df.loc[((df['indel_type'] == 'INS') & 
    (df['SD_snap_back_lk'].isna())), 'SD_snap_back_lk'] = 0
df.loc[((df['indel_type'] == 'INS') & 
    (df['SD_loop_out_lk'].isna())), 'SD_loop_out_lk'] = 0



df['del_mmej_lk'] = 1 - df['del_mmej_lk']
df['del_mmej_lk_MH2'] = 1 - df['del_mmej_lk_MH2']


df['del_mmej_lk'].fillna(value=0, inplace=True)
df['del_mmej_lk_MH2'].fillna(value=0, inplace=True)
df['pChance_MMEJ'].fillna(value=1, inplace=True)

df['del_mmej_p_val'].fillna(value=1, inplace=True)
df['del_mmej_p_val_MH2'].fillna(value=1, inplace=True)
df['pChance_MMEJ_MH2'].fillna(value=1, inplace=True)
df['SD_snap_back_p_val'].fillna(value=1, inplace=True)
df['SD_loop_out_p_val'].fillna(value=1, inplace=True)
df['pChance_snap'].fillna(value=1, inplace=True)
df['pChance_loop'].fillna(value=1, inplace=True)



"""
Sice the Markov model calculates the probability to find 2 motifs in a
defined range and a given context, this probability is the probability
that something isn't MMEJ, therefore if one wants to have the probability
of something to be a MMEJ, he should do 1-probability
"""

# convert indel length of deletions to negative its length
df.loc[(df['indel_type'] == 'DEL'), 'indel_len'] = df.loc[(df['indel_type'] == 'DEL'), 'indel_len'] * (-1)

"""
Annotating NHEJ as 1-(all the other repair mechanisms)
Calculating NHEJ prob as 1-(max(all the other repair mechnisms prob))
"""

# insertions that are not any type of MMEJ will be called for now: unclassified_ins
df.loc[:,'unclassified_ins'] = False
df.loc[((df['indel_type'] == 'INS') &
       (df['SD_snap_back'] == False) &
       (df['SD_loop_out'] == False)),'unclassified_ins'] = True

df.loc[:,'NHEJ'] = False

df.loc[((df['indel_type'] == 'DEL') & (df['del_mmej'] == False)), 'NHEJ'] = True

df.loc[:,'NHEJ_lk'] = 0
df.loc[:,'NHEJ_p_val'] = 1


df.loc[(df['indel_type'] == 'DEL'),'NHEJ_lk'] = df.apply(lambda x: (1-x['del_mmej_lk']), axis = 1)
df.loc[(df['indel_type'] == 'DEL'),'NHEJ_p_val'] = df.apply(lambda x: (1-x['del_mmej_p_val']), axis = 1)

df.loc[:,'NHEJ_lk_MH2'] = 0
df.loc[:,'NHEJ_p_val_MH2'] = 1
df.loc[(df['indel_type'] == 'DEL'),'NHEJ_lk_MH2'] = df.apply(lambda x: (1-x['del_mmej_lk_MH2']), axis = 1)
df.loc[(df['indel_type'] == 'DEL'),'NHEJ_p_val_MH2'] = df.apply(lambda x: (1-x['del_mmej_p_val_MH2']), axis = 1)



df.loc[:,'unclassified_ins_p_val'] = 1

df.loc[(df['indel_type'] == 'INS'),'unclassified_ins_p_val'] = df.apply(lambda x: (1-(x[[
                     'SD_snap_back_p_val',
                     'SD_loop_out_p_val']].max())), axis = 1)

# Evaluating insertion mechanisms proportions
# Adding a column with number of realingments
var_id_count = df['variant_id'].value_counts()
var_id_count = var_id_count.reset_index()
df = df.merge(var_id_count,left_on='variant_id', right_on='index',how="left")
df.drop(columns=['index'], inplace=True)
df.rename(columns={'variant_id_y': 'variant_id_N', 'variant_id_x': 'variant_id'}, inplace=True)

col_to_save = ['CHR', 
        'POS', 'original_pos','variant_id', 'variant_id_N','direction','ancestral_indel', 'derived_indel', 
        'del_mmej_lk', 'del_mmej_p_val', 

        'SDMMEJ_lk','SD_snap_back_lk','SD_snap_back_lk_bc','SD_snap_back_p_val', 'pChance_snap',
        'snap_repeat_pat', 'snap_repeat_pat_len','snap_freq_motif_eq',
        'SD_loop_out_lk', 'SD_loop_out_lk_bc', 'SD_loop_out_p_val','pChance_loop', 'loop_freq_motif_eq',
        'loop_repeat_pat', 'loop_repeat_pat_len',
        'NHEJ_lk','NHEJ_p_val', 

        'unclassified_ins_lk', 'unclassified_ins_p_val',
        'indel_len','del_mmej_cand','del_mmej_cand_len','del_mmej_freq_motif_eq',
        'del_mmej_lk_MH2', 'del_mmej_p_val_MH2','pChance_MMEJ',
        'pChance_MMEJ_MH2', 'NHEJ_lk_MH2', 'NHEJ_p_val_MH2', 
        'del_mmej_motif_pos', 'del_mmej_freq_small_window', 'del_mmej_freq_large_window',
        'loop_motif_pos', 'loop_freq_small_window', 'loop_freq_large_window',
        'snap_motif_pos', 'snap_freq_small_window', 'snap_freq_large_window']


df_mechanisms_prob = df.loc[:, col_to_save]
logging.debug({k:str(v[0]) for k,v in pd.DataFrame(df_mechanisms_prob.dtypes).T.to_dict('list').items()})

file_name = args["vcf"].split('.')[0]
df.loc[:, col_to_save].to_csv(f'{output_file}', index=False, sep='\t')

# print(df.loc[:, ['del_mmej_lk', 'del_mmej_p_val', 'pChance_MMEJ']])
